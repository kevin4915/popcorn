<div class="show-wrapper">

  <%= link_to root_path, class: "show-back" do %>
    ← Retour
  <% end %>

  <div class="show-poster">
    <% if @movie.poster_url.present? %>
      <%= image_tag @movie.poster_url, alt: @movie.title %>
    <% end %>
  </div>

  <h1 class="show-title">
    <%= @movie.title %>
    <% if @movie.year.present? %>
      (<%= @movie.year %>)
    <% end %>
  </h1>

  <% if @movie.director.present? %>
    <p class="show-director">
      De <%= @movie.director %>
    </p>
  <% end %>

  <% if @movie.category.present? %>
    <p class="show-category">
      <%= @movie.category %>
    </p>
  <% end %>

  <div class="show-meta">
    <% if @movie.duration.present? %>
      <span>⏱️ <%= @movie.duration %> min</span>
    <% end %>

    <% if @movie.rating.present? %>
      <span>⭐ <%= @movie.rating %>/5</span>
    <% end %>
  </div>

  <% if @movie.synopsis.present? %>
    <p class="show-description">
      <%= @movie.synopsis %>
    </p>
  <% end %>


  <% if @platforms.present? %>
    <div class="show-platforms">

      <h2 class="show-section-title">
        Disponible sur
      </h2>

      <div class="platform-tags">
        <% @platforms.each do |platform| %>
          <span class="platform-tag">
            <%= platform %>
          </span>
        <% end %>
      </div>

    </div>
  <% end %>


  <% if @actors.present? %>
    <div class="show-cast">

      <h2>Acteurs principaux</h2>

      <div class="actors-scroll">

        <% @actors.each do |actor| %>

          <div class="actor-card">

            <% if actor["photo_url"].present? %>
              <%= image_tag actor["photo_url"],
                alt: actor["name"],
                class: "actor-photo" %>
            <% else %>
              <div class="actor-photo-placeholder">
                🎭
              </div>
            <% end %>

            <div class="actor-name">
              <%= actor["name"] %>
            </div>

            <% if actor["character"].present? %>
              <div class="actor-character">
                <%= actor["character"] %>
              </div>
            <% end %>

          </div>

        <% end %>

      </div>

    </div>
  <% end %>


  <% if @movie.trailer.present? %>

    <div class="show-trailer">

      <h2 class="show-section-title">
        Bande-annonce
      </h2>

      <div class="trailer-frame">

        <iframe
          src="https://www.youtube.com/embed/<%= @movie.trailer %>"
          title="Bande annonce"
          frameborder="0"
          allowfullscreen>
        </iframe>

      </div>

    </div>
  <% else %>
    <p class="show-trailer-empty">
      Aucune bande-annonce disponible.
    </p>
  <% end %>

</div>
