<div class="show-wrapper">

  <%= link_to params[:from] == "historics" ? historics_path : root_path, class: "show-back" do %>
    ← Retour
  <% end %>

  <div class="show-poster">
    <%= image_tag @movie.poster_url, alt: @movie.title %>
  </div>

  <h1 class="show-title">
    <%= @movie.title %>
    <% if @movie.year.present? %>
      (<%= @movie.year %>)
    <% end %>
  </h1>

  <% if @movie.director.present? %>
    <p class="show-director">De <%= @movie.director %></p>
  <% end %>

  <% if @movie.category.present? %>
    <p class="show-category">
      Catégorie : <%= @movie.category %>
    </p>
  <% end %>

  <div class="show-meta">
    <% if @movie.duration.present? %>
      <span>⏱️ <%= @movie.duration %> min</span>
    <% end %>

    <% if @movie.rating.present? %>
      <span>⭐ <%= @movie.rating %>/5</span>
    <% end %>
  </div>

  <p class="show-description">
    <%= @movie.synopsis.presence || "Synopsis indisponible." %>
  </p>

  <% if @actors.present? %>
    <div class="show-actors">
      <h2 class="show-section-title">Acteurs principaux</h2>
      <p><%= @actors.join(", ") %></p>
    </div>
  <% end %>

  <% if @platforms.present? %>
    <div class="show-platforms">
      <h2 class="show-section-title">Disponible sur</h2>
      <div class="platform-tags">
        <% @platforms.each do |platform| %>
          <span class="platform-tag"><%= platform %></span>
        <% end %>
      </div>

      <%= link_to "#", class: "show-watch-button" do %>
        Voir le film sur <%= @platforms.first %>
      <% end %>
    </div>
  <% else %>
    <div class="show-platforms">
      <h2 class="show-section-title">Disponible sur</h2>
      <p class="show-platforms-empty">
        Aucune plateforme renseignée pour la France.
      </p>
    </div>
  <% end %>

  <% if @movie.trailer.present? %>
    <div class="show-trailer">
      <h2 class="show-section-title">Bande-annonce</h2>

      <div class="trailer-frame">
        <iframe
          width="100%"
          height="315"
          src="https://www.youtube.com/embed/<%= @movie.trailer %>"
          title="Bande-annonce de <%= @movie.title %>"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% else %>
    <div class="show-trailer">
      <h2 class="show-section-title">Bande-annonce</h2>
      <p class="show-trailer-empty">
        Aucune bande-annonce disponible.
      </p>
    </div>
  <% end %>

</div>
