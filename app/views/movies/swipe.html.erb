<div class="swipe-wrapper">
  <div class="swipe-container" data-controller="swipe">
    <% if @movies.empty? %>
      <div class="empty-state">
        <i class="fa-solid fa-film" style="font-size: 3rem; margin-bottom: 1rem;"></i>
        <p>Aucun film trouvé pour ces critères...</p>
        <%= link_to "🍿 Modifier ma recherche", root_path, class: "btn-action" %>
      </div>
    <% else %>
      <% @movies.reverse.each_with_index do |movie, index| %>
        <div class="swipe-card"
             data-swipe-target="card"
             data-movie-id="<%= movie.id %>"
             style="z-index: <%= 10 - index %>;">
          <% total = @movies.count %>
          <div class="progress-bar">
            <div class="progress" style="width: <%= ((index + 1).to_f / total) * 100 %>%"></div>
          </div>
          <%= image_tag movie.poster_url, alt: movie.title, referrerpolicy: "no-referrer" %>
          <div class="card-info">
            <h3><%= movie.title %> (<%= movie.year %>)</h3>
            <p class="rating">Note : ⭐ <%= movie.rating || "4.5" %>/5</p>
            <p class="synopsis"><%= movie.synopsis&.truncate(120) %></p>
            <div class="actors-section">
              <strong>Acteurs :</strong>
              <p class="actors-list"><%= movie.actors %></p>
            </div>
          </div>
          <div class="card-actions">
            <button class="btn-dislike"
                    data-action="click->swipe#handleSwipe"
                    data-decision="dislike">
              <i class="fa-solid fa-xmark"></i>
            </button>
            <button class="btn-like"
                    data-action="click->swipe#handleSwipe"
                    data-decision="like">
              <i class="fa-solid fa-heart"></i>
            </button>
          </div>

          <p class="synopsis">
            <%= movie.synopsis.present? ? truncate(movie.synopsis, length: 140) : "Synopsis indisponible." %>
          </p>

          <% if movie.actors.present? %>
            <div class="actors-section">
              <strong>Acteurs principaux</strong>
              <p class="actors-list"><%= movie.actors %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="end-state" data-swipe-target="endState" style="display: none;">
        <p>Tu as vu tous les films !</p>
        <%= link_to "🍿 Nouvelle recherche", root_path, class: "btn-action" %>
      </div>
    <% end %>
  </div>
</div>
