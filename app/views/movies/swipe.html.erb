<div class="swipe-container" data-controller="swipe">
  <% if @movies.blank? %>
    <div class="empty-state">
      <i class="fa-solid fa-film empty-state-icon" aria-hidden="true"></i>
      <p>Plus de films trouvés !</p>
      <%= link_to "Recharger la liste", root_path, class: "btn-reset" %>
    </div>
  <% else %>
    <% total = @movies.size %>

    <% @movies.reverse.each_with_index do |movie, index| %>
      <% progress = ((total - index).to_f / total * 100).round %>

      <article
        class="movie-card"
        data-swipe-target="card"
        data-movie-id="<%= movie.id %>"
        style="z-index: <%= total - index %>;"
      >
        <div class="progress-bar" aria-label="Progression dans la liste">
          <div
            class="progress"
            style="width: <%= progress %>%"
            aria-valuenow="<%= progress %>"
            aria-valuemin="0"
            aria-valuemax="100"
            role="progressbar"
          ></div>
        </div>

        <div class="movie-poster-wrapper">
          <%= image_tag(
                movie.poster_url.presence || "placeholder-poster.png",
                alt: "Affiche de #{movie.title}",
                class: "movie-poster",
                referrerpolicy: "no-referrer"
              ) %>
        </div>

        <div class="card-info">
          <h3 class="movie-title">
            <%= movie.title %>
            <% if movie.year.present? %>
              <span class="movie-year">(<%= movie.year %>)</span>
            <% end %>
          </h3>

          <div class="movie-meta">
            <p class="rating">
              ⭐ <%= movie.rating.present? ? movie.rating : "Non noté" %>
              <% if movie.rating.present? %>/5<% end %>
            </p>

            <% if movie.duration.present? %>
              <p class="duration">⏱ <%= movie.duration %> min</p>
            <% end %>

            <% if movie.category.present? %>
              <p class="category">🎬 <%= movie.category %></p>
            <% end %>
          </div>

          <p class="synopsis">
            <%= movie.synopsis.present? ? truncate(movie.synopsis, length: 140) : "Synopsis indisponible." %>
          </p>

          <% if movie.actors.present? %>
            <div class="actors-section">
              <strong>Acteurs principaux</strong>
              <p class="actors-list"><%= movie.actors %></p>
            </div>
          <% end %>
        </div>

        <div class="card-actions">
          <button
            type="button"
            class="btn-dislike"
            data-action="click->swipe#handleSwipe"
            data-decision="dislike"
            aria-label="Refuser ce film"
          >
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>

          <button
            type="button"
            class="btn-like"
            data-action="click->swipe#handleSwipe"
            data-decision="like"
            aria-label="Aimer ce film"
          >
            <i class="fa-solid fa-heart" aria-hidden="true"></i>
          </button>
        </div>
      </article>
    <% end %>

    <div class="end-state" data-swipe-target="endState" hidden>
      <p>Tu as vu tous les films !</p>
      <%= link_to "🍿 Nouvelle recherche", root_path, class: "btn-action" %>
    </div>
  <% end %>
</div>
