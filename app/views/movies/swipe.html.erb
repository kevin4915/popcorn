<div class="swipe-wrapper">
  <div class="swipe-container" data-controller="swipe">
    <% if @movies.blank? %>
      <div class="empty-state">
        <i class="fa-solid fa-film" style="font-size: 3rem; margin-bottom: 1rem;"></i>
        <p>Aucun film trouvé pour ces critères...</p>
        <%= link_to "🍿 Modifier ma recherche", root_path, class: "btn-action" %>
      </div>
    <% else %>
      <% total = @movies.count %>

      <% @movies.reverse.each_with_index do |movie, index| %>
        <article
          class="swipe-card"
          data-swipe-target="card"
          data-movie-id="<%= movie.id %>"
          style="z-index: <%= total - index %>;"
        >
          <div class="progress-bar">
            <div
              class="progress"
              style="width: <%= ((index + 1).to_f / total) * 100 %>%"
            ></div>
          </div>

          <div class="swipe-poster-wrap">
            <%= image_tag(
                  movie.poster_url.presence || "placeholder-poster.png",
                  alt: movie.title,
                  referrerpolicy: "no-referrer"
                ) %>
            <% if movie.rating.present? %>
              <span class="popcorn-rating-badge">⭐ <%= movie.rating %>/5</span>
            <% end %>
          </div>

          <div class="card-info">
            <h3>
              <%= movie.title %>
              <% if movie.year.present? %>
                (<%= movie.year %>)
              <% end %>
            </h3>

            <div class="movie-details-section">
              <span>🎬 <%= movie.category.presence || "—" %></span>
              <span>⏱️ <%= movie.duration.present? ? "#{movie.duration} min" : "—" %></span>
              <span>🎞️ <%= movie.year.presence || "—" %></span>
            </div>

            <p class="synopsis">
              <%= movie.synopsis.present? ? truncate_at_sentence(movie.synopsis, 250) : "Synopsis indisponible." %>
            </p>

          </div>

          <div class="card-actions">
            <button
              type="button"
              class="btn-dislike"
              data-action="click->swipe#handleSwipe"
              data-decision="dislike"
              aria-label="Refuser ce film"
            >
              <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>

            <button
              type="button"
              class="btn-like"
              data-action="click->swipe#handleSwipe"
              data-decision="like"
              aria-label="Aimer ce film"
            >
              <i class="fa-solid fa-heart" aria-hidden="true"></i>
            </button>
          </div>
        </article>
      <% end %>

      <div class="end-state" data-swipe-target="endState" style="display: none;">
        <p>Tu as vu tous les films !</p>
        <%= link_to "🍿 Nouvelle recherche", root_path, class: "btn-action" %>
      </div>
    <% end %>
  </div>
</div>
