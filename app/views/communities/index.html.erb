<div class="popcorn-wrapper">
  <h1 class="popcorn-title">Communauté</h1>

  <div class="community-tabs">
    <%= link_to "Tout le monde", community_path(filter: 'all'),     class: "community-tab #{@filter == 'all' ? 'active' : ''}" %>
    <%= link_to "Mes amis",      community_path(filter: 'friends'), class: "community-tab #{@filter == 'friends' ? 'active' : ''}" %>
  </div>

  <% if @recent_likes.empty? %>
    <div class="community-empty">
      <p>
        <% if @filter == 'friends' %>
          Aucun ami n'a encore liké de film. <%= link_to "Trouver des amis", community_path(filter: 'all') %> !
        <% else %>
          Aucune activité récente.
        <% end %>
      </p>
    </div>
  <% end %>

  <div class="community-feed">
    <% @recent_likes.each do |historic| %>
      <div class="popcorn-card-wrapper">
        <div class="popcorn-card" style="position: relative;">

          <% if current_user != historic.user %>
            <% unless current_user.friend_with?(historic.user) || current_user.pending_request_sent_to?(historic.user) %>
              <%= link_to friendships_path(friend_id: historic.user.id),
              method: :post,
              class: "btn-add-friend btn-add-friend-corner",
              data: { turbo_method: :post } do %>
                <i class="fa-solid fa-user-plus"></i>
              <% end %>
            <% end %>
          <% end %>

          <div class="popcorn-poster-wrapper">
            <%= link_to movie_path(historic.movie, from: "community"), class: "popcorn-poster" do %>
              <%= image_tag historic.movie.poster_url.presence || asset_path("no-poster.png"), alt: historic.movie.title %>
              <span class="popcorn-rating-badge">⭐ <%= historic.movie.rating || "—" %></span>
              <% likes_count = Historic.where(movie: historic.movie, liked: true).count %>
              <% dislikes_count = Historic.where(movie: historic.movie, disliked: true).count %>
              <% if likes_count > 0 || dislikes_count > 0 %>
                <span class="votes-badge">
                  <% if likes_count > 0 %>
                    <span class="vote-up"><i class="fa-solid fa-thumbs-up"></i> <%= likes_count %></span>
                  <% end %>
                  <% if dislikes_count > 0 %>
                    <span class="vote-down"><i class="fa-solid fa-thumbs-down"></i> <%= dislikes_count %></span>
                  <% end %>
                </span>
              <% end %>
            <% end %>

            <div data-controller="watchlist"
                 data-watchlist-added-value="<%= current_user.movies.include?(historic.movie) %>"
                 style="position: absolute; top: 6px; right: 6px;">
              <button class="btn-historic-action btn-watchlist-corner <%= current_user.movies.include?(historic.movie) ? 'btn-added' : 'btn-add-list' %>"
                      data-watchlist-target="btn"
                      data-action="click->watchlist#toggle"
                      data-movie-id="<%= historic.movie.id %>">
                <i data-watchlist-target="icon" class="fa-solid <%= current_user.movies.include?(historic.movie) ? 'fa-check' : 'fa-heart' %>"></i>
              </button>
            </div>
          </div>

          <div class="popcorn-info">
            <div class="mt-1">
              <h2 class="community-activity">
                <%= link_to profile_path(historic.user), class: "user-name" do %>
                  <span class="user-username">@<%= historic.user.username %></span>
                <% end %>
                <% historic.user.badges.each do |badge| %>
                  <span class="popcorn-badge" title="<%= badge.description %>"><%= badge.icon %></span>
                <% end %>
                a aimé <strong><%= historic.movie.title %></strong>
              </h2>

              <p class="popcorn-category"><%= historic.movie.media_type == "tv" ? "📺 Série" : "🎥 Film" %></p>
              <p class="popcorn-category">🎬 <%= historic.movie.category %></p>
              <div class="popcorn-meta">
                <span class="popcorn-year">🎞️ <%= historic.movie.year || "?" %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
<%= paginate @recent_likes %>
