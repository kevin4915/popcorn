<div class="popcorn-wrapper">
  <h1 class="popcorn-title">Communauté</h1>

  <div class="community-tabs">
    <%= link_to "Tout le monde", community_path(filter: 'all'),     class: "community-tab #{@filter == 'all' ? 'active' : ''}" %>
    <%= link_to "Mes amis",      community_path(filter: 'friends'), class: "community-tab #{@filter == 'friends' ? 'active' : ''}" %>
  </div>

  <% if @recent_likes.empty? %>
    <div class="community-empty">
      <p>
        <% if @filter == 'friends' %>
          Aucun ami n'a encore liké de film. <%= link_to "Trouver des amis", community_path(filter: 'all') %> !
        <% else %>
          Aucune activité récente.
        <% end %>
      </p>
    </div>
  <% end %>

  <div class="community-feed">
    <% @recent_likes.each do |historic| %>
      <div class="popcorn-card horizontal community-card">
        <div class="popcorn-poster">
          <%= image_tag historic.movie.poster_url, alt: historic.movie.title %>
        </div>

        <div class="popcorn-info">
          <p class="community-activity">
            <span class="user-identity">
              <%= link_to profile_path(historic.user), class: "user-name" do %>
                <%= historic.user.first_name %>
                <span class="user-username">@<%= historic.user.username %></span>
              <% end %>
              <span class="badges-container">
                <% historic.user.badges.each do |badge| %>
                  <span class="popcorn-badge" title="<%= badge.description %>">
                    <%= badge.icon %>
                  </span>
                <% end %>
              </span>
            </span>
            a aimé <strong><%= historic.movie.title %></strong>
          </p>

          <div class="popcorn-meta">
            ⭐ <%= historic.movie.rating || "—" %>/5
            <span class="popcorn-year">🎞️ <%= historic.movie.year %></span>
          </div>

          <p class="popcorn-description">
            <%= truncate(historic.movie.synopsis, length: 150) %>
          </p>

          <%= link_to "Voir le film", movie_path(historic.movie), class: "btn-popcorn-small" %>

          <% if current_user != historic.user %>
            <% unless current_user.friend_with?(historic.user) || current_user.pending_request_sent_to?(historic.user) %>
              <%= button_to "➕ Ajouter @#{historic.user.username}",
                  friendships_path(friend_id: historic.user.id),
                  method: :post,
                  class: "btn-popcorn-small btn-add-friend" %>
            <% end %>
          <% end %>

          <div class="community-comments">
            <% historic.comments.each do |comment| %>
              <div class="comment-item">
                <%= link_to profile_path(comment.user), class: "comment-author" do %>
                  <strong><%= comment.user.first_name %></strong>
                  <span class="text-muted">@<%= comment.user.username %></span>
                <% end %>
                : <%= comment.content %>
              </div>
            <% end %>

            <%= form_with model: [historic, Comment.new], class: "comment-form" do |f| %>
              <%= f.text_field :content, placeholder: "Ajouter un commentaire...", class: "comment-input" %>
              <%= f.submit "Envoyer", class: "btn-popcorn-small" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
