<div class="popcorn-wrapper">
  <h1 class="popcorn-title">Mes films</h1>

  <% @movies.each do |movie| %>
    <div class="popcorn-card-wrapper">
      <div class="popcorn-card">
        <%= link_to movie_path(movie, from: "historics"), class: "popcorn-poster" do %>
          <%= image_tag movie.poster_url, alt: movie.title %>
          <span class="popcorn-rating-badge">⭐ <%= movie.rating || "—" %></span>
        <% end %>

        <div class="popcorn-info">
          <%= link_to movie_path(movie, from: "historics"), class: "popcorn-info-link" do %>
            <h2><%= movie.title %></h2>
            <p class="popcorn-category">🎬 <%= movie.category %></p>
            <p class="popcorn-duration">⏱️ <%= movie.duration %> min</p>
            <div class="popcorn-meta">
              <span class="popcorn-year">🎞️ <%= movie.year || "?" %></span>
            </div>
            <p class="popcorn-description"><%= movie.synopsis %></p>
          <% end %>

          <div class="popcorn-actions">
            <div class="popcorn-actions-left">
              <button class="btn-historic-action btn-thumbs-up">
                <i class="fa-solid fa-thumbs-up"></i>
              </button>

              <button class="btn-historic-action btn-thumbs-down">
                <i class="fa-solid fa-thumbs-down"></i>
              </button>
            </div>

            <%= button_to historic_path(current_user.historics.find_by(movie: movie)),
                          method: :delete,
                          class: "btn-delete-historic",
                          form: { data: { turbo_confirm: "Retirer ce film de ta liste ?" } } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
