<div class="popcorn-wrapper">
  <div class="profile-card-large">

    <div class="profile-header-main">
      <div class="avatar-container">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar-img" %>
        <% else %>
          <%= image_tag "avatar_default.avif", class: "profile-avatar-img" %>
        <% end %>
      </div>

      <div class="badge-frame">
        <h1 class="profile-name"><%= @user.first_name %></h1>
        <p class="profile-username">@<%= @user.username %></p>
        <% if @user.badges.any? %>
          <div class="badge-item-fancy">
            <span><%= @user.badges.first.icon %></span>
            <span><%= @user.badges.first.name %></span>
          </div>
        <% end %>
      </div>

      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-value"><%= @user.liked_movies_count %></span>
          <span class="stat-label">Films likés</span>
        </div>
        <div class="stat-item">
          <span class="stat-value"><%= @user.friends.count %></span>
          <span class="stat-label">Amis</span>
        </div>
      </div>
    </div>

    <% if current_user != @user %>
      <div class="profile-footer-actions">
        <% if current_user.friend_with?(@user) %>
          <span class="friend-status friend-accepted">✅ Vous êtes amis</span>
          <% friendship = current_user.friendship_with(@user) %>
          <%= button_to "Retirer des amis", friendship_path(friendship),
              method: :delete,
              form: { data: { turbo_confirm: "Retirer @#{@user.username} de vos amis ?" } },
              class: "btn-popcorn-danger btn-sm" %>

        <% elsif current_user.pending_request_sent_to?(@user) %>
          <span class="friend-status friend-pending">⏳ Demande envoyée</span>
          <% friendship = current_user.sent_friendships.find_by(friend: @user, status: 'pending') %>
          <%= button_to "Annuler la demande", friendship_path(friendship),
              method: :delete,
              class: "btn-popcorn-outline btn-sm" %>

        <% elsif current_user.pending_request_received_from?(@user) %>
          <% friendship = current_user.received_friendships.find_by(user: @user, status: 'pending') %>
          <div class="friend-request-actions">
            <p class="friend-request-text">@<%= @user.username %> vous a envoyé une demande d'ami</p>
            <%= button_to "✅ Accepter", accept_friendship_path(friendship), method: :patch, class: "btn-popcorn btn-sm" %>
            <%= button_to "❌ Refuser", decline_friendship_path(friendship), method: :patch, class: "btn-popcorn-danger btn-sm" %>
          </div>

        <% else %>
          <%= button_to "➕ Ajouter en ami", friendships_path(friend_id: @user.id),
              method: :post, class: "btn-popcorn" %>
        <% end %>
      </div>
    <% end %>

    <% if current_user == @user && @pending_requests&.any? %>
      <div class="profile-section pending-requests">
        <h3>Demandes d'amis en attente 🔔 (<%= @pending_requests.count %>)</h3>
        <% @pending_requests.each do |friendship| %>
          <div class="pending-request-item">
            <div class="pending-request-user">
              <% if friendship.user.avatar.attached? %>
                <%= image_tag friendship.user.avatar, class: "mini-avatar" %>
              <% else %>
                <%= image_tag "avatar_default.avif", class: "mini-avatar" %>
              <% end %>
              <div>
                <strong><%= friendship.user.first_name %></strong>
                <span class="text-muted">@<%= friendship.user.username %></span>
              </div>
            </div>
            <div class="pending-request-actions">
              <%= button_to "✅ Accepter", accept_friendship_path(friendship), method: :patch, class: "btn-popcorn btn-sm" %>
              <%= button_to "❌ Refuser", decline_friendship_path(friendship), method: :patch, class: "btn-popcorn-danger btn-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="profile-section">
      <h3>Mes Plateformes</h3>
      <div class="platform-flex">
        <% platforms = {
          "Netflix"     => "Logo_netflix.png",
          "DisneyPlus"  => "Logo_disney.png",
          "AmazonPrime" => "Logo_amazon_prime.png",
          "CanalPlus"   => "Logo_canal.png",
          "HBO"         => "Logo_HBO.png"
        } %>
        <% platforms.each do |name, logo| %>
          <% if @user.send(name) %>
            <span class="platform-chip">
              <%= image_tag logo, style: "width: 20px;" %>
              <%= name.gsub("Plus", "+").gsub("Prime", " Prime") %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="profile-section">
      <h3>Derniers coups de cœur</h3>
      <div class="movies-carousel">
        <% @user.recent_liked_movies.each do |movie| %>
          <%= link_to movie_path(movie), class: "carousel-movie-card" do %>
            <%= image_tag movie.poster_url, alt: movie.title %>
            <div class="movie-mini-info">
              <span>⭐ <%= movie.rating %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @user.friends.any? %>
      <div class="profile-section">
        <h3>Amis (<%= @user.friends.count %>)</h3>
        <div class="friends-list">
          <% @user.friends.each do |friend| %>
            <%= link_to profile_path(friend), class: "friend-item" do %>
              <% if friend.avatar.attached? %>
                <%= image_tag friend.avatar, class: "mini-avatar" %>
              <% else %>
                <%= image_tag "avatar_default.avif", class: "mini-avatar" %>
              <% end %>
              <div>
                <strong><%= friend.first_name %></strong>
                <span class="text-muted">@<%= friend.username %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
