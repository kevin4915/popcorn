<div class="popcorn-wrapper">
  <div class="profile-card-large">
    <div class="profile-header-main">
      <div class="avatar-container">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar-img", alt: @user.username %>
        <% else %>
          <%= image_tag "avatar_default.avif", class: "profile-avatar-img", alt: "Avatar par défaut" %>
        <% end %>
      </div>
      <div class="badge-frame">
        <h1 class="profile-name"><%= @user.username %></h1>
        <% if @user.badges.any? %>
          <div class="badge-item-fancy">
            <span><%= @user.badges.first.icon %></span>
            <span><%= @user.badges.first.name %></span>
          </div>
        <% end %>
      </div>
      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-value"><%= @user.liked_movies_count %></span>
          <span class="stat-label">Films likés</span>
        </div>
        <div class="stat-item">
          <span class="stat-value"><%= @user.friends.count %></span>
          <span class="stat-label">Amis</span>
        </div>
      </div>
    </div>

    <div class="profile-section">
      <h3>Mes Plateformes</h3>
      <div class="calendar-divider"></div>
      <div class="platform-flex">
        <% platforms = { "Netflix" => "Logo_netflix.png", "DisneyPlus" => "Logo_disney.png", "AmazonPrime" => "Logo_amazon_prime.png", "CanalPlus" => "Logo_canal.png", "HBO" => "Logo_HBO.png" } %>
        <% platforms.each do |name, logo| %>
          <% if @user.send(name) %>
            <span class="platform-chip">
              <%= image_tag logo, style: "width: 20px;" %> <%= name.gsub("Plus", "+").gsub("Prime", " Prime") %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="profile-section">
      <h3>Derniers coups de cœur</h3>
      <div class="calendar-divider"></div>
      <div class="calendar-grid">
        <% @recent_movies.each do |movie| %>
          <%= link_to movie_path(movie), class: "mini-movie-card" do %>
            <div class="mini-poster-wrap">
              <% if movie.poster_url.present? %>
                <%= image_tag movie.poster_url, class: "mini-poster", alt: movie.title %>
              <% else %>
                <div class="mini-poster-placeholder">Pas d'affiche</div>
              <% end %>

              <% if movie.rating.present? %>
                <span class="popcorn-rating-badge">⭐ <%= movie.rating %></span>
              <% end %>

              <div class="mini-card-overlay">
                <h3><%= movie.title %></h3>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="profile-footer-actions">
      <% if current_user != @user %>
        <% if current_user.friends.include?(@user) %>
          <span class="friend-status">✅ Amis</span>
        <% elsif current_user.sent_friendships.exists?(friend: @user, status: 'pending') %>
          <span class="friend-status">⏳ Demande en attente</span>
        <% else %>
          <%= button_to "Ajouter en ami", friendships_path(friend_id: @user.id), method: :post, class: "btn-popcorn" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
