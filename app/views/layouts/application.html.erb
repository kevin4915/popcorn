<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Popcorn" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Popcorn">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if current_user %>
      <div class="header">
        <%= link_to root_path do %>
          <%= image_tag "logo.png", class: "logo" %>
        <% end %>
        <p>Bienvenue, <%= current_user.first_name %></p>

        <div class="avatar-dropdown" id="avatarDropdown">
          <div class="badge-wrapper" style="position: relative; display: inline-block;">
            <%= image_tag "avatar_default.avif", class: "avatar" %>

            <% if user_signed_in? %>
              <div style="position: absolute; top: -5px; left: -5px; display: flex; gap: 2px;">
                <% current_user.badges.each do |badge| %>
                  <span title="<%= badge.description %>" style="background: #e50914; color: white; border-radius: 50%; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; font-size: 10px; border: 2px solid #1a1a1a;">
                    <%= badge.icon %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="dropdown-menu-custom" id="dropdownMenu">
            <%= link_to "Communauté", community_path %>
            <%= link_to "Accéder à mes films", historics_path %>
            <%= link_to "Calendrier des sorties", calendar_path %>
            <%= link_to "Gérer mon compte", edit_user_registration_path %>
            <%= link_to "Se déconnecter", destroy_user_session_path, data: { turbo_method: :delete } %>
          </div>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
