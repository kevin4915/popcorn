<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Popcorn" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Popcorn">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if current_user %>
      <div class="header">
        <div class="header-left">
          <%= link_to root_path, class: "header-logo-link" do %>
            <%= image_tag "logo.png", class: "logo" %>
          <% end %>
        </div>

        <div class="header-center">
          <p>Bienvenue, <%= current_user.first_name %></p>
        </div>

        <div class="header-right">
          <div class="avatar-dropdown" id="avatarDropdown">
            <div class="badge-wrapper">
              <div class="avatar-shell">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "avatar", alt: current_user.first_name %>
                <% else %>
                  <%= image_tag "avatar_default.avif", class: "avatar", alt: "Avatar par défaut" %>
                <% end %>
              </div>

              <% if user_signed_in? && current_user.badges.any? %>
                <div class="badges-layer">
                  <% current_user.badges.each do |badge| %>
                    <span class="badge-dot" title="<%= badge.description %>">
                      <%= badge.icon %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="dropdown-menu-custom" id="dropdownMenu">
              <%= link_to "Communauté", community_path %>
              <%= link_to "Mes films", films_historics_path %>
              <%= link_to "Mes séries", series_historics_path %>
              <%= link_to "Calendrier des sorties", calendar_path %>
              <%= link_to "Gérer mon compte", edit_user_registration_path %>
              <%= link_to "Se déconnecter", destroy_user_session_path, data: { turbo_method: :delete } %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
