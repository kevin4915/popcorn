<div class="cinema-welcome">
  <div class="cinema-projector-beam"></div>

  <div class="cinema-curtain curtain-left"></div>
  <div class="cinema-curtain curtain-right"></div>

  <div class="cinema-stage">
    <div class="cinema-screen-glow"></div>

    <div class="cinema-logo-wrap">
      <%= image_tag "logo.png", class: "cinema-logo", alt: "Popcorn" %>
    </div>

    <h1 class="cinema-title">Popcorn</h1>

    <div class="cinema-user">
      <% if current_user&.avatar&.attached? %>
        <%= image_tag current_user.avatar, class: "cinema-avatar", alt: current_user.first_name %>
      <% else %>
        <%= image_tag "avatar_default.avif", class: "cinema-avatar", alt: "Avatar par défaut" %>
      <% end %>
    </div>

    <p class="cinema-message">
      Content de te revoir <strong><%= current_user.first_name %></strong>
    </p>

    <p class="cinema-submessage">
      Installe-toi, la séance commence…
    </p>

    <div class="cinema-loader">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>

  <script>
    setTimeout(() => {
      window.location.href = "<%= root_path %>"
    }, 3200)
  </script>
</div>
