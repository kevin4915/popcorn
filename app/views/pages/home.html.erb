<div class="choice" data-controller="media-toggle">
  <h2>Qu'est-ce qu'on regarde ce soir ? 🍿</h2>

  <%= form_with url: movies_path, method: :get do |f| %>
    <div class="toggle">
      <span>Film</span>

      <%= f.check_box :serie,
            class: "toggle-input",
            data: {
              action: "change->media-toggle#updateForm",
              "media-toggle-target": "toggle"
            } %>

      <span>Série</span>
    </div>

    <div data-media-toggle-target="durationBlock">
      <p>Temps disponible</p>
      <div class="durations">
        <%= f.radio_button :duration, "1h30", id: "d1h30" %>
        <%= label_tag "d1h30", "1h30" %>

        <%= f.radio_button :duration, "2h", id: "d2h" %>
        <%= label_tag "d2h", "2h" %>

        <%= f.radio_button :duration, "2h30+", id: "d2h30" %>
        <%= label_tag "d2h30", "2h30+" %>
      </div>
    </div>

    <p>Avec qui ?</p>
    <div class="company">
      <%= f.radio_button :company, "seul", id: "c_seul" %>
      <%= label_tag "c_seul", "Seul" %>

      <%= f.radio_button :company, "potes", id: "c_potes" %>
      <%= label_tag "c_potes", "Entre potes" %>

      <%= f.radio_button :company, "famille", id: "c_famille" %>
      <%= label_tag "c_famille", "En famille" %>
    </div>

    <p>Genre</p>
    <%= f.select :genre,
          [],
          { include_blank: "Choisir un genre" },
          data: { "media_toggle_target": "genreSelect" } %>

    <button type="submit" class="btn-action">
      <%= image_tag "logo.png", class: "btn-logo" %>
      Moteur ... Action !
    </button>
  <% end %>

  <div class="search-divider">ou</div>

  <%= form_with url: search_movies_path, method: :get do |f| %>
    <div class="search-bar">
      <%= f.text_field :q,
            placeholder: "Rechercher un film ou une série...",
            class: "search-input",
            autocomplete: "off" %>
      <%= f.submit "Rechercher", class: "search-submit" %>
    </div>
  <% end %>
</div>

<% if @top_day.present? %>
  <div class="top10">
    <h3>Top 10 des tendances du jour</h3>

    <div class="carousel-container">
      <button class="carousel-btn" data-carousel="day" data-direction="-1">‹</button>

      <div class="movies-row" id="carousel-day">
        <% @top_day.each do |movie| %>
          <%= link_to movie_path(movie), class: "movie-card-thumb" do %>
            <%= image_tag movie.poster_url, class: "poster-thumb", alt: movie.title %>
          <% end %>
        <% end %>
      </div>

      <button class="carousel-btn" data-carousel="day" data-direction="1">›</button>
    </div>
  </div>
<% end %>
