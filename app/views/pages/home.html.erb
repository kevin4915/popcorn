<div class="choice" data-controller="media-toggle">
  <h2>Qu'est-ce qu'on regarde ce soir ? 🍿</h2>

  <%= form_with url: movies_path, method: :get do |f| %>
    <div class="toggle">
      <span>Film</span>

      <%= f.check_box :serie,
            class: "toggle-input",
            data: {
              action: "change->media-toggle#updateForm",
              "media-toggle-target": "toggle"
            } %>

      <span>Série</span>
    </div>

    <div data-media-toggle-target="durationBlock">
      <p>Temps disponible</p>
      <div class="durations">
        <%= f.radio_button :duration, "1h30", id: "d1h30" %>
        <%= label_tag "d1h30", "1h30" %>

        <%= f.radio_button :duration, "2h", id: "d2h" %>
        <%= label_tag "d2h", "2h" %>

        <%= f.radio_button :duration, "2h30+", id: "d2h30" %>
        <%= label_tag "d2h30", "2h30+" %>
      </div>
    </div>

    <p>Avec qui ?</p>
    <div class="company">
      <%= f.radio_button :company, "seul", id: "c_seul" %>
      <%= label_tag "c_seul", "Seul" %>

      <%= f.radio_button :company, "potes", id: "c_potes" %>
      <%= label_tag "c_potes", "Entre potes" %>

      <%= f.radio_button :company, "famille", id: "c_famille" %>
      <%= label_tag "c_famille", "En famille" %>
    </div>

    <p>Genre</p>
    <%= f.select :genre,
          [],
          { include_blank: "Choisir un genre" },
          data: { "media-toggle-target": "genreSelect" } %>

    <button type="submit" class="btn-action">
      <%= image_tag "logo.png", class: "btn-logo" %>
      Moteur ... Action !
    </button>
  <% end %>

  <div class="search-divider">ou</div>

  <%= form_with url: search_movies_path, method: :get do |f| %>
    <div class="search-bar">
      <%= f.text_field :q,
            placeholder: "Rechercher un film ou une série...",
            class: "search-input",
            autocomplete: "off" %>
      <button type="submit" class="search-submit">
        <i class="bi bi-search"></i>
      </button>
    </div>
  <% end %>

</div>

<div class="top-section" data-controller="home-tabs">
  <div class="top-tabs">
    <button
      type="button"
      class="top-tab active"
      data-home-tabs-target="tab"
      data-action="click->home-tabs#showFilms"
    >
      Top 10 films
    </button>

    <button
      type="button"
      class="top-tab"
      data-home-tabs-target="tab"
      data-action="click->home-tabs#showSeries"
    >
      Top 10 séries
    </button>

    <button
      type="button"
      class="top-tab"
      data-home-tabs-target="tab"
      data-action="click->home-tabs#showForYou">
      Pour vous
    </button>
  </div>

  <div data-home-tabs-target="filmsPanel">
    <% if @top_day.present? %>
      <div class="top10">
        <h3>Top 10 des tendances du jour</h3>

        <div class="carousel-container">
          <button class="carousel-btn" data-carousel="day" data-direction="-1">‹</button>

          <div class="movies-row" id="carousel-day">
            <% @top_day.each do |movie| %>
              <%= link_to movie_path(movie), class: "movie-card-thumb" do %>
                <%= image_tag movie.poster_url, class: "poster-thumb", alt: movie.title %>
              <% end %>
            <% end %>
          </div>

          <button class="carousel-btn" data-carousel="day" data-direction="1">›</button>
        </div>
      </div>
    <% end %>
  </div>

  <div data-home-tabs-target="seriesPanel" style="display: none;">
    <% if @top_tv_fr.present? %>
      <div class="top10">
        <h3>Top 10 des séries en France</h3>

        <div class="carousel-container">
          <button class="carousel-btn" data-carousel="tv-fr" data-direction="-1">‹</button>

          <div class="movies-row" id="carousel-tv-fr">
            <% @top_tv_fr.each do |serie| %>
              <%= link_to movie_path(serie), class: "movie-card-thumb" do %>
                <%= image_tag serie.poster_url, class: "poster-thumb", alt: serie.title %>
              <% end %>
            <% end %>
          </div>

          <button class="carousel-btn" data-carousel="tv-fr" data-direction="1">›</button>
        </div>
      </div>
    <% end %>
  </div>

  <div data-home-tabs-target="forYouPanel" style="display: none;">
  <% if @for_you.present? %>

    <div class="top10">
      <h3>Recommandé pour vous</h3>

      <div class="carousel-container">
        <button class="carousel-btn" data-carousel="for-you" data-direction="-1">‹</button>

        <div class="movies-row" id="carousel-for-you">
          <% @for_you.each do |movie| %>
            <%= link_to movie_path(movie), class: "movie-card-thumb" do %>
              <%= image_tag movie.poster_url,
                    class: "poster-thumb",
                    alt: movie.title %>
            <% end %>
          <% end %>
        </div>

        <button class="carousel-btn" data-carousel="for-you" data-direction="1">›</button>
      </div>

    </div>

    <% end %>
  </div>

</div>
