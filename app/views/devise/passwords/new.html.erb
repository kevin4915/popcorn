<div class="login-page">
  <div class="login-card">
    <%= image_tag "logo.png", class: "login-logo" %>
    <h2>Mot de passe oublié ? 🍿</h2>
    <p class="login-subtitle">Entrez votre adresse email pour recevoir un lien de réinitialisation</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :email,
                  label: "Adresse email",
                  required: true,
                  autofocus: true,
                  input_html: { autocomplete: "email", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.button :submit, "🍿 Recevoir mon mot de passe", class: "btn-action mt-3" %>

      <div class="login-links">
        <%= render "devise/shared/links" %>
      </div>

    <% end %>
  </div>
</div>
