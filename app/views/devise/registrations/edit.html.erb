<div class="login-page">
  <div class="login-card">
    <%= image_tag "logo.png", class: "login-logo" %>
    <h2>Mon profil 🍿</h2>
    <p class="login-subtitle">Mettez à jour vos informations personnelles et gérez vos abonnements</p>

    <%= simple_form_for(
          resource,
          as: resource_name,
          url: registration_path(resource_name),
          html: { method: :put, multipart: true }
        ) do |f| %>
      <%= f.error_notification %>

    <div class="profile-avatar-section" data-controller="avatar-preview">
      <p class="login-label">Photo de profil</p>

      <div class="profile-avatar-preview">
        <% if resource.avatar.attached? && resource.persisted?%>
          <%= image_tag resource.avatar,
                class: "profile-avatar-image",
                alt: "Avatar du user",
                data: { avatar_preview_target: "image" } %>
        <% else %>
          <%= image_tag "avatar_default.avif",
                class: "profile-avatar-image",
                alt: "Avatar par défaut",
                data: { avatar_preview_target: "image" } %>
        <% end %>
      </div>

      <label class="avatar-upload-btn">
        📷 Changer la photo
        <%= f.file_field :avatar,
              accept: "image/*",
              class: "avatar-input",
              data: {
                action: "change->avatar-preview#preview",
                avatar_preview_target: "input"
              } %>
      </label>
    </div>

      <%= f.input :first_name,
                  required: true,
                  label: "Prénom",
                  input_html: { class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.input :last_name,
                  required: true,
                  label: "Nom",
                  input_html: { class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.input :username,
                  required: true,
                  label: "Pseudo",
                  input_html: { class: "login-input" },
                  label_html: { class: "login-label" },
                  error_html: { class: "invalid-feedback d-block" } %>

      <%= f.input :email,
                  required: true,
                  label: "Adresse e-mail",
                  input_html: { class: "login-input" },
                  label_html: { class: "login-label" } %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="alert alert-warning mt-3 mb-3">
          En attente de confirmation pour : <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <%= f.input :password,
                  required: false,
                  label: "Nouveau mot de passe",
                  hint: "Laisser vide si vous ne voulez pas le changer",
                  input_html: { autocomplete: "new-password", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.input :password_confirmation,
                  required: false,
                  label: "Confirmer le nouveau mot de passe",
                  input_html: { autocomplete: "new-password", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.input :current_password,
                  required: true,
                  label: "Mot de passe actuel",
                  hint: "Nous avons besoin de votre mot de passe actuel pour confirmer vos modifications",
                  input_html: { autocomplete: "current-password", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <p class="login-label">Mes abonnements</p>
      <div class="subscriptions-grid">
        <label class="subscription-option">
          <%= f.check_box :Netflix, class: "subscription-checkbox" %>
          <div class="subscription-card">
            <span class="subscription-checkmark">✓</span>
            <%= image_tag "Logo_netflix.png", class: "subscription-logo", alt: "Netflix" %>
            <span class="subscription-name">Netflix</span>
          </div>
        </label>

        <label class="subscription-option">
          <%= f.check_box :DisneyPlus, class: "subscription-checkbox" %>
          <div class="subscription-card">
            <span class="subscription-checkmark">✓</span>
            <%= image_tag "Logo_disney.png", class: "subscription-logo", alt: "Disney+" %>
            <span class="subscription-name">Disney+</span>
          </div>
        </label>

        <label class="subscription-option">
          <%= f.check_box :AmazonPrime, class: "subscription-checkbox" %>
          <div class="subscription-card">
            <span class="subscription-checkmark">✓</span>
            <%= image_tag "Logo_amazon_prime.png", class: "subscription-logo", alt: "Amazon Prime" %>
            <span class="subscription-name">Amazon Prime</span>
          </div>
        </label>

        <label class="subscription-option">
          <%= f.check_box :CanalPlus, class: "subscription-checkbox" %>
          <div class="subscription-card">
            <span class="subscription-checkmark">✓</span>
            <%= image_tag "Logo_canal.png", class: "subscription-logo", alt: "Canal+" %>
            <span class="subscription-name">Canal+</span>
          </div>
        </label>

        <label class="subscription-option">
          <%= f.check_box :HBO, class: "subscription-checkbox" %>
          <div class="subscription-card">
            <span class="subscription-checkmark">✓</span>
            <%= image_tag "Logo_HBO.png", class: "subscription-logo", alt: "HBO" %>
            <span class="subscription-name">HBO</span>
          </div>
        </label>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 12px;">
        <%= link_to "← Retour", request.referer || root_path, class: "btn-action" %>
        <%= f.button :submit, "🍿 Enregistrer", class: "btn-action" %>
      </div>

      <div class="login-links">
        <%= render "devise/shared/links" %>
      </div>
    <% end %>
  </div>
</div>
