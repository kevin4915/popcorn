<div class="login-page">
  <div class="login-card">
    <%= image_tag "logo.png", class: "login-logo" %>
    <h2>Bienvenue sur PopCorn 🍿</h2>
    <p class="login-subtitle">Connectez-vous pour accéder à l'application</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  label: "Adresse email",
                  input_html: { autocomplete: "email", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <%= f.input :password,
                  label: "Mot de passe",
                  required: false,
                  input_html: { autocomplete: "current-password", class: "login-input" },
                  label_html: { class: "login-label" } %>

      <% if devise_mapping.rememberable? %>
        <%= f.input :remember_me,
                    as: :boolean,
                    label: "Se souvenir de moi",
                    wrapper_html: { class: "remember-wrapper" } %>
      <% end %>

      <%= f.button :submit, "🍿 Se connecter", class: "btn-action mt-3" %>

    <% end %>

    <div class="login-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
